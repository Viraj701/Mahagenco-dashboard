# MAHAGENCO Centralized Monitoring System - Environment Variables

# ===== APPLICATION =====
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# ===== DATABASE =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mahagenco_dashboard
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_NAME=mahagenco_dashboard
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===== REDIS CACHE =====
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=mahagenco:

# ===== JWT AUTHENTICATION =====
JWT_SECRET=your-very-long-secret-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-very-long-refresh-secret-key
JWT_REFRESH_EXPIRE=30d

# ===== FRONTEND =====
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_WS_URL=ws://localhost:5000
REACT_APP_ENVIRONMENT=development
REACT_APP_LOG_LEVEL=debug

# ===== EXTERNAL INTEGRATIONS =====
# SCADA/EMS Integration
SCADA_API_URL=http://scada-server:8080/api
SCADA_API_KEY=your-scada-api-key
SCADA_SYNC_INTERVAL_SECONDS=300

# Early Fault Detection System
EFDS_API_URL=http://efds-server:8080/api
EFDS_API_KEY=your-efds-api-key
EFDS_SYNC_INTERVAL_SECONDS=60

# Finance System Integration
FINANCE_API_URL=http://finance-system:8080/api
FINANCE_API_KEY=your-finance-api-key
FINANCE_SYNC_TIME=08:00

# Plant Data Sources
PLANT_1_DATASOURCE=http://plant1-dcs:8080
PLANT_2_DATASOURCE=http://plant2-dcs:8080
# ... Continue for all 8 plants

# ===== EMAIL NOTIFICATIONS =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=mahagenco-dashboard@mahagenco.com
SMTP_FROM_NAME=MAHAGENCO Dashboard

# ===== SMS ALERTS =====
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+919876543210

# ===== SLACK INTEGRATION =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CRITICAL_CHANNEL=#mahagenco-critical-alerts
SLACK_WARNING_CHANNEL=#mahagenco-warnings

# ===== AWS/CLOUD SERVICES =====
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=mahagenco-dashboard-reports
AWS_CLOUDWATCH_ENABLED=true

# ===== MONITORING & OBSERVABILITY =====
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456
DATADOG_API_KEY=your-datadog-api-key
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# ===== SECURITY =====
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_KEY_SECRET=your-api-key-secret

# ===== FEATURE FLAGS =====
FEATURE_PREDICTIVE_MAINTENANCE=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_MOBILE_APP=false
FEATURE_EXTERNAL_INTEGRATIONS=true
FEATURE_CUSTOM_REPORTS=true

# ===== BACKUP & RECOVERY =====
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# ===== DEVELOPMENT ONLY =====
DEBUG=mahagenco:*
MOCK_EXTERNAL_APIS=false
SEED_DATABASE=false
VERBOSE_LOGGING=true

# ===== PRODUCTION SETTINGS =====
# Set these only in production
# USE_HTTPS=true
# CERTIFICATE_PATH=/etc/ssl/certs
# PRIVATE_KEY_PATH=/etc/ssl/private
# SESSION_SECRET=production-session-secret
# MAX_REQUEST_SIZE=10mb
